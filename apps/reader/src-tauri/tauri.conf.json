{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComicHub Reader",
  "version": "0.0.0",
  "identifier": "com.comichub.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ComicHub Reader",
        "width": 1100,
        "height": 820,
        "minWidth": 600,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png", "icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["cbz", "cbr", "cb7", "cbt"],
        "name": "Comic Book Archive",
        "description": "Comic book archive",
        "role": "Viewer"
      }
    ]
  }
}
