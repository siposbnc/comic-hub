{
  "name": "comic-hub",
  "version": "0.0.0",
  "private": true,
  "description": "ComicHub — a library platform for comics. Monorepo: Go media server + Tauri client + Tauri reader.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "codegen": "node tools/codegen/gen-formats.mjs",
    "codegen:check": "node tools/codegen/gen-formats.mjs --check",
    "dev:client": "pnpm --filter @comichub/client tauri dev",
    "dev:reader": "pnpm --filter @comichub/reader tauri dev",
    "dev:client:web": "pnpm --filter @comichub/client dev",
    "dev:reader:web": "pnpm --filter @comichub/reader dev",
    "build:client": "pnpm --filter @comichub/client tauri build",
    "build:reader": "pnpm --filter @comichub/reader tauri build",
    "build:installers": "pnpm run build:client && pnpm run build:reader",
    "lint": "pnpm -r run lint && pnpm lint:ds",
    "lint:ds": "eslint apps",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0"
  }
}
