# Copy to .env for local development. Secrets must never be committed.

# Metadata provider API keys (Phase 2). Server-side only — never exposed to clients.
# COMICVINE_API_KEY=

# Point the client's Rust core at a specific server binary (overrides dev path lookup).
# COMICHUB_SERVER_BIN=D:/Dev/comic-hub/server/bin/comichub-server.exe
